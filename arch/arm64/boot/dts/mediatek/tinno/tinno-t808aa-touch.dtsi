&pio {
	spi2_pins: spi2@0 {
		pins_spi {
			pinmux = <PINMUX_GPIO39__FUNC_SPI2_CSB>,
					<PINMUX_GPIO38__FUNC_SPI2_CLK>,
					<PINMUX_GPIO40__FUNC_SPI2_MO>,
					<PINMUX_GPIO41__FUNC_SPI2_MI>;
			bias-disable;
		};
	};

	spi2_pins_sleep: spi2@1 {
		pins_spi {
			pinmux = <PINMUX_GPIO39__FUNC_GPIO39>,
					<PINMUX_GPIO38__FUNC_GPIO38>,
					<PINMUX_GPIO40__FUNC_GPIO40>,
					<PINMUX_GPIO41__FUNC_GPIO41>;
			output-low;
		};
	};
};

