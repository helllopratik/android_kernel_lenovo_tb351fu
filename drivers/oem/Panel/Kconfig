#
#  DRM_PANEL configuration
#
config DRM_PANEL_BOE_NT36523N_VDO
	tristate "boe nt36523n video 90hz panel"
	depends on OF
	depends on DRM_MIPI_DSI
	depends on BACKLIGHT_CLASS_DEVICE
	help
	  Say Y here if you want to enable support for nt36523 fhdplus and
	  wqhd cmd panel. The panel has a 1200x2000 resolution
	  and uses 24-bits RGB per pixel. It provides a MIPI DSI
	  interface to host.
	  
config DRM_PANEL_CSOT_NT36523N_VDO
	tristate "csot nt36523n video 90hz panel"
	depends on OF
	depends on DRM_MIPI_DSI
	depends on BACKLIGHT_CLASS_DEVICE
	help
	  Say Y here if you want to enable support for nt36523 fhdplus and
	  wqhd cmd panel. The panel has a 1200x2000 resolution
	  and uses 24-bits RGB per pixel. It provides a MIPI DSI
	  interface to host.
